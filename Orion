local mouselock = false
function OrionLib:UnlockMouse(Value)
    if Value then
        mouselock = true
        task.spawn(function()
            while mouselock do
                UserInputService.MouseIconEnabled = true
                freeMouse.Visible = true
                task.wait()
            end
            freeMouse.Visible = false
        end)
    else
        mouselock = false
    end
end

-- Orion X仕様: カラー自動生成
function OrionLib:GenTheme(mainColor)
    local r, g, b = mainColor.R * 255, mainColor.G * 255, mainColor.B * 255
    local lum = 0.299 * r + 0.587 * g + 0.114 * b
    local dark = lum < 128
    local t = {Main = mainColor}
    
    if dark then
        t.Second = Color3.fromRGB(math.clamp(r * 1.15, 0, 255), math.clamp(g * 1.15, 0, 255), math.clamp(b * 1.15, 0, 255))
        t.Stroke = Color3.fromRGB(math.clamp(r * 1.4, 0, 255), math.clamp(g * 1.4, 0, 255), math.clamp(b * 1.4, 0, 255))
        t.Divider = Color3.fromRGB(math.clamp(r * 1.25, 0, 255), math.clamp(g * 1.25, 0, 255), math.clamp(b * 1.25, 0, 255))
        t.Text = Color3.fromRGB(240, 240, 240)
        t.TextDark = Color3.fromRGB(150, 150, 150)
        t.Accent = Color3.fromRGB(math.clamp(r * 1.8, 0, 255), math.clamp(g * 1.8, 0, 255), math.clamp(b * 1.8, 0, 255))
    else
        t.Second = Color3.fromRGB(math.clamp(r * 0.9, 0, 255), math.clamp(g * 0.9, 0, 255), math.clamp(b * 0.9, 0, 255))
        t.Stroke = Color3.fromRGB(math.clamp(r * 0.7, 0, 255), math.clamp(g * 0.7, 0, 255), math.clamp(b * 0.7, 0, 255))
        t.Divider = Color3.fromRGB(math.clamp(r * 0.8, 0, 255), math.clamp(g * 0.8, 0, 255), math.clamp(b * 0.8, 0, 255))
        t.Text = Color3.fromRGB(30, 30, 30)
        t.TextDark = Color3.fromRGB(100, 100, 100)
        t.Accent = Color3.fromRGB(math.clamp(r * 0.6, 0, 255), math.clamp(g * 0.6, 0, 255), math.clamp(b * 0.6, 0, 255))
    end
    return t
end

-- Orion X仕様: 外部からタブ切り替え
function OrionLib:GoToTab(tabName)
    for name, data in pairs(Tabs) do
        if name == tabName then
            data.Container.Visible = true
            TweenService:Create(data.Button, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
        else
            data.Container.Visible = false
            TweenService:Create(data.Button, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
        end
    end
end

-- Orion本来の主要構造: Window作成
function OrionLib:MakeWindow(WindowConfig)
    WindowConfig = WindowConfig or {}
    local WindowName = WindowConfig.Name or "Orion Library"
    
    -- ここでOrion特有のMainFrameアセット群、Sidebar、TopBarを生成
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0, 550, 0, 350)
    MainFrame.Position = UDim2.new(0.5, -275, 0.5, -175)
    MainFrame.BackgroundColor3 = OrionLib.Themes.Default.Main
    MainFrame.BorderSizePixel = 0
    MainFrame.Parent = Orion
    
    local Corner = Instance.new("UICorner", MainFrame)
    Corner.CornerRadius = UDim.new(0, 8)
    
    local TopBar = Instance.new("Frame", MainFrame)
    TopBar.Name = "TopBar"
    TopBar.Size = UDim2.new(1, 0, 0, 40)
    TopBar.BackgroundTransparency = 1
    
    local Title = Instance.new("TextLabel", TopBar)
    Title.Text = WindowName
    Title.Size = UDim2.new(1, -40, 1, 0)
    Title.Position = UDim2.new(0, 15, 0, 0)
    Title.TextColor3 = OrionLib.Themes.Default.Text
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 16
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.BackgroundTransparency = 1

    local Sidebar = Instance.new("Frame", MainFrame)
    Sidebar.Name = "Sidebar"
    Sidebar.Size = UDim2.new(0, 150, 1, -40)
    Sidebar.Position = UDim2.new(0, 0, 0, 40)
    Sidebar.BackgroundColor3 = OrionLib.Themes.Default.Second
    Sidebar.BorderSizePixel = 0
    
    local SidebarCorner = Instance.new("UICorner", Sidebar)
    SidebarCorner.CornerRadius = UDim.new(0, 8)

    local TabPack = Instance.new("ScrollingFrame", Sidebar)
    TabPack.Size = UDim2.new(1, 0, 1, 0)
    TabPack.BackgroundTransparency = 1
    TabPack.ScrollBarThickness = 2
    
    local TabList = Instance.new("UIListLayout", TabPack)
    TabList.Padding = UDim.new(0, 5)

    local ContentViewport = Instance.new("Frame", MainFrame)
    ContentViewport.Name = "ContentViewport"
    ContentViewport.Size = UDim2.new(1, -160, 1, -50)
    ContentViewport.Position = UDim2.new(0, 155, 0, 45)
    ContentViewport.BackgroundTransparency = 1

    -- ドラッグ設定
    MakeDraggable(TopBar, MainFrame)

    local WindowElements = {}
    local FirstTab = true

    -- タブ作成
    function WindowElements:MakeTab(TabConfig)
        TabConfig = TabConfig or {}
        local TabName = TabConfig.Name or "Tab"
        
        local TabButton = Instance.new("TextButton", TabPack)
        TabButton.Size = UDim2.new(1, -10, 0, 30)
        TabButton.BackgroundColor3 = OrionLib.Themes.Default.Accent
        TabButton.BackgroundTransparency = FirstTab and 0 or 1
        TabButton.Text = TabName
        TabButton.TextColor3 = OrionLib.Themes.Default.Text
        TabButton.Font = Enum.Font.GothamSemibold
        TabButton.TextSize = 14
        
        local BtnCorner = Instance.new("UICorner", TabButton)
        BtnCorner.CornerRadius = UDim.new(0, 6)

        local Container = Instance.new("ScrollingFrame", ContentViewport)
        Container.Size = UDim2.new(1, 0, 1, 0)
        Container.BackgroundTransparency = 1
        Container.Visible = FirstTab
        Container.ScrollBarThickness = 4
        
        local ContainerList = Instance.new("UIListLayout", Container)
        ContainerList.Padding = UDim.new(0, 6)

        -- 外部アクセス用テーブルへ登録
        Tabs[TabName] = {Button = TabButton, Container = Container}

        TabButton.MouseButton1Click:Connect(function()
            OrionLib:GoToTab(TabName)
        end)

        FirstTab = false

        -- Orion本来の各種Element（Button, Toggle等）の生成ロジック
        local TabElements = {}

        -- Button
        function TabElements:AddButton(BtnConfig)
            BtnConfig = BtnConfig or {}
            local text = BtnConfig.Name or "Button"
            local callback = BtnConfig.Callback or function() end
            
            local ButtonFrame = Instance.new("Frame", Container)
            ButtonFrame.Size = UDim2.new(1, -10, 0, 35)
            ButtonFrame.BackgroundColor3 = OrionLib.Themes.Default.Second
            
            local bCorner = Instance.new("UICorner", ButtonFrame)
            bCorner.CornerRadius = UDim.new(0, 6)
            
            local TextBtn = Instance.new("TextButton", ButtonFrame)
            TextBtn.Size = UDim2.new(1, 0, 1, 0)
            TextBtn.BackgroundTransparency = 1
            TextBtn.Text = text
            TextBtn.TextColor3 = OrionLib.Themes.Default.Text
            TextBtn.Font = Enum.Font.Gotham
            TextBtn.TextSize = 14
            
            TextBtn.MouseButton1Click:Connect(function()
                pcall(callback)
            end)
        end

        -- Toggle
        function TabElements:AddToggle(ToggleConfig)
            ToggleConfig = ToggleConfig or {}
            local text = ToggleConfig.Name or "Toggle"
            local default = ToggleConfig.Default or false
            local callback = ToggleConfig.Callback or function() end
            local flag = ToggleConfig.Flag or text
            
            local ToggleFrame = Instance.new("Frame", Container)
            ToggleFrame.Size = UDim2.new(1, -10, 0, 35)
            ToggleFrame.BackgroundColor3 = OrionLib.Themes.Default.Second
            
            local tCorner = Instance.new("UICorner", ToggleFrame)
            tCorner.CornerRadius = UDim.new(0, 6)
            
            local Label = Instance.new("TextLabel", ToggleFrame)
            Label.Text = text
            Label.Size = UDim2.new(1, -50, 1, 0)
            Label.Position = UDim2.new(0, 10, 0, 0)
            Label.TextColor3 = OrionLib.Themes.Default.Text
            Label.Font = Enum.Font.Gotham
            Label.TextSize = 14
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.BackgroundTransparency = 1
            
            local Indicator = Instance.new("Frame", ToggleFrame)
            Indicator.Size = UDim2.new(0, 20, 0, 20)
            Indicator.Position = UDim2.new(1, -30, 0, 7)
            Indicator.BackgroundColor3 = default and OrionLib.Themes.Default.Accent or OrionLib.Themes.Default.Main
            Instance.new("UICorner", Indicator).CornerRadius = UDim.new(0, 4)
            
            local Clicker = Instance.new("TextButton", ToggleFrame)
            Clicker.Size = UDim2.new(1, 0, 1, 0)
            Clicker.BackgroundTransparency = 1
            Clicker.Text = ""
            
            local Toggled = default
            OrionLib.Flags[flag] = {
                Value = Toggled,
                Set = function(self, v)
                    Toggled = v
                    Indicator.BackgroundColor3 = Toggled and OrionLib.Themes.Default.Accent or OrionLib.Themes.Default.Main
                    pcall(callback, Toggled)
                end
            }
            
            Clicker.MouseButton1Click:Connect(function()
                Toggled = not Toggled
                OrionLib.Flags[flag]:Set(Toggled)
            end)
        end

        return TabElements
    end

    return WindowElements
end

return OrionLib
